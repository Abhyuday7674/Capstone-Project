    <worksheet name='Drop-off Analysis'>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_sessions+' name='federated.0qi85qi06v8cff1ce8q1u14dei09' />
          </datasources>
          <datasource-dependencies datasource='federated.0qi85qi06v8cff1ce8q1u14dei09'>
            <column caption='Drop Landing to Product' datatype='integer' name='[Calculation_1318147361468911624]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([has_landing_view]) - SUM([has_product_view])' />
            </column>
            <column caption='Drop Product to Cart' datatype='integer' name='[Calculation_1318147361469054985]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([has_product_view]) - SUM([has_add_to_cart])' />
            </column>
            <column caption='Drop Cart to Checkout' datatype='integer' name='[Calculation_1318147361469116426]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([has_add_to_cart]) - SUM([has_begin_checkout])' />
            </column>
            <column caption='Drop Checkout to Payment' datatype='integer' name='[Calculation_1318147361469177867]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([has_begin_checkout]) - SUM([has_payment_attempt])' />
            </column>
            <column caption='Drop Payment to Purchase' datatype='integer' name='[Calculation_1318147361469239308]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([has_payment_attempt]) - SUM([has_purchase])' />
            </column>
            <column caption='Discount Amount' datatype='real' name='[discount_amount]' role='measure' type='quantitative' />
            <column caption='Has Add To Cart' datatype='integer' name='[has_add_to_cart]' role='measure' type='quantitative' />
