      <column caption='Converted' datatype='integer' name='[Calculation_1318147361347657729]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [net_amount] &gt; 0 THEN 1 ELSE 0 END' />
      </column>
      <column caption='Revenue per Session' datatype='real' name='[Calculation_1318147361351483394]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([net_amount]) / COUNTD([session_id])' />
      </column>
      <column caption='Funnel Step' datatype='string' name='[Calculation_1318147361459224579]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [has_landing_view] = 1 THEN &quot;Landing&quot;&#13;&#10;END' />
      </column>
      <column caption='Landing Sessions' datatype='integer' name='[Calculation_1318147361464135684]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [has_landing_view] = 1 THEN 1 END' />
      </column>
      <column caption='Product View' datatype='integer' name='[Calculation_1318147361464299525]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [has_product_view] = 1 THEN 1 END' />
      </column>
      <column caption='Add to Cart' datatype='integer' name='[Calculation_1318147361464463366]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [has_add_to_cart] = 1 THEN 1 END' />
      </column>
      <column caption='Drop Landing to Product' datatype='integer' name='[Calculation_1318147361468911624]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([has_landing_view]) - SUM([has_product_view])' />
      </column>
      <column caption='Drop Product to Cart' datatype='integer' name='[Calculation_1318147361469054985]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([has_product_view]) - SUM([has_add_to_cart])' />
      </column>
      <column caption='Drop Cart to Checkout' datatype='integer' name='[Calculation_1318147361469116426]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([has_add_to_cart]) - SUM([has_begin_checkout])' />
      </column>
      <column caption='Drop Checkout to Payment' datatype='integer' name='[Calculation_1318147361469177867]' role='measure' type='quantitative'>
